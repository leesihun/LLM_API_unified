# Copy this file to .env and edit values. start.sh sources .env automatically.
# This is the single source of truth for Messenger runtime config.

# --- Network ---
# HTTP/Socket.IO listen port for the Messenger server
PORT=10006

# --- Storage ---
# Directory for SQLite DB and other persistent app data
MESSENGER_DATA_DIR=./server/data
# Directory where uploaded files are stored after assembly
MESSENGER_UPLOADS_DIR=./server/uploads
# Temporary directory for in-progress chunked upload pieces
MESSENGER_CHUNKS_DIR=./server/chunks
# Root for the file-browser/storage routes (/api/files)
MESSENGER_STORAGE_DIR=./server/storage
# Static asset directory served at the server root
MESSENGER_PUBLIC_DIR=./server/public
# Built Vite client (dist-web) served as the web UI
MESSENGER_WEB_DIR=./client/dist-web

# --- Auth/Security ---
# Shared secret required to open WebSocket terminal sessions (claude/opencode)
SECRET_TOKEN=leesihun

# --- Integrations ---
# Working directory that Claude/OpenCode terminal sessions operate inside
WORKSPACE_DIR=/scratch0
# Command name (or absolute path) used to spawn the Claude Code CLI
CLAUDE_CMD=claude
# Command name (or absolute path) used to spawn the OpenCode CLI
OPENCODE_CMD=opencode

# --- Behavior ---
# Set to "1" when Messenger runs inside the Electron host so it skips its own listen()
# Leave unset for normal standalone web/server mode.
# MESSENGER_EMBEDDED=
